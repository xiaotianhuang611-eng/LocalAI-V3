# Normalize text files
* text=auto

# Python / scripts / docs
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wav binary
*.mp3 binary
*.mp4 binary
*.gguf binary
*.bin binary
*.safetensors binary
*.pt binary
*.pth binary
*.pkl binary
